{
  "displayName": "Homebridge Netcast TV",
  "name": "homebridge-netcast-tv",
  "version": "3.0.0",
  "description": "Homebridge plugin to interact with LG Netcast TVs",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jausto/homebridge-netcast-tv"
  },
  "bugs": {
    "url": "https://github.com/jausto/homebridge-netcast-tv/issues"
  },
  "engines": {
    "node": "^18.20.0 || ^20.18.0 || ^22.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint src/**.ts --max-warnings=0",
    "watch": "npm run build && npm link && nodemon",
